# Production environment variables for VVZ Explorer
# Copy this file to .env and fill in your values.

# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key

# Comma-separated list of allowed hostnames
DJANGO_ALLOWED_HOSTS=localhost,your-domain.com,your-vps-ip
